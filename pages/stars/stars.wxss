.container {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.header {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 60rpx;
  margin-bottom: 40rpx;
}

.title {
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.count {
  font-size: 24rpx;
  color: #666;
  margin-top: 10rpx;
}

.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-top: 200rpx;
}

.empty-text {
  font-size: 32rpx;
  color: #999;
}

.empty-hint {
  font-size: 28rpx;
  color: #bbb;
  margin-top: 16rpx;
}

.word-list {
  width: 100%;
  display: flex;
  flex-direction: column;
}

.word-item {
  position: relative;
  padding: 24rpx 30rpx;
  background: white;
  border-radius: 12rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
  overflow: hidden;
}

.word-main {
  display: flex;
  justify-content: space-between;
  align-items: center;
}

.expand-panel {
  left: 0;
  right: 0;
  height: 0;
  background: linear-gradient(135deg, #07c160, #04a85a);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  transition: height 0.3s ease;
  overflow: hidden;
}

.word-item.open .expand-panel {
  height: 120rpx;
  bottom: 0;
}

.word-zh {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
  font-weight: bold;
}

.word-example {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
  font-weight: bold;
  margin-top: 8rpx;
  padding: 0 20rpx;
  text-align: center;
}

.word-text {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
}

.remove-btn {
  font-size: 28rpx;
  color: #999;
  padding: 10rpx 20rpx;
}

.remove-btn:active {
  color: #f44336;
}

.back-btn {
  width: 80%;
  margin-top: 40rpx;
  background-color: #576775;
  color: white;
  border-radius: 8rpx;
}