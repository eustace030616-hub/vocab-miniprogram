.status-bar {
  width: 100%;
  height: 65rpx;
  background:#f5f5f5;
}

.container {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background-color: #f5f5f5;
}

/* Progress Bar */
.progress {
  width: 100%;
  height: 16rpx;
  background: #e0e0e0;
  border-radius: 8rpx;
  overflow: hidden;
  margin-bottom: 10rpx;
}

.progress-inner {
  height: 100%;
  background: linear-gradient(90deg, #07c160, #10b760);
  border-radius: 8rpx;
  transition: width 0.3s ease;
}

.progress-text {
  text-align: center;
  margin: 10rpx 0 20rpx;
  font-size: 28rpx;
  color: #666;
}

/* Level Info */
.level-info {
  display: flex;
  justify-content: space-between;
  width: 100%;
  padding: 20rpx 30rpx;
  background: white;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

.user-level {
  font-size: 32rpx;
  font-weight: bold;
  color: #07c160;
}

.user-score {
  font-size: 32rpx;
  font-weight: bold;
  color: #ff9800;
}

.vocab-animate {
  color: #ff5722;
  animation: vocab-pulse 0.5s ease-in-out infinite alternate;
}

@keyframes vocab-pulse {
  from { transform: scale(1); }
  to { transform: scale(1.15); }
}

/* Word Box */
.word-box {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin: 40rpx 0;
  padding: 50rpx 60rpx;
  background: white;
  border-radius: 20rpx;
  min-width: 85%;
  box-shadow: 0 4rpx 12rpx rgba(0,0,0,0.1);
}

.word {
  font-size: 56rpx;
  font-weight: bold;
  color: #333;
}

.level-badge {
  font-size: 24rpx;
  color: #666;
  background: #f5f5f5;
  padding: 8rpx 20rpx;
  border-radius: 16rpx;
  margin-top: 15rpx;
}

/* Answer Options */
.options {
  width: 100%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.option-btn {
  width: 85%;
  margin: 12rpx 0;
  background: white;
  border: 2rpx solid #ddd;
  border-radius: 12rpx;
  font-size: 34rpx;
  color: #333;
  padding: 24rpx 30rpx;
  box-shadow: 0 2rpx 6rpx rgba(0,0,0,0.05);
}

.option-btn:active {
  background: #e8f5e9;
  border-color: #07c160;
  transform: scale(0.98);
}

/* Not Sure Button */
.not-sure-btn {
  width: 85%;
  margin: 30rpx 0 15rpx;
  background: none;
  border: 2rpx dashed #ccc;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #999;
  padding: 20rpx;
}

.not-sure-btn:active {
  background: #f5f5f5;
}

/* Exit Button */
.exit-btn {
  margin-top: 30rpx;
  color: #999;
  font-size: 24rpx;
  background: none;
  border: none;
  padding: 10rpx 20rpx;
}

.exit-btn:active {
  color: #666;
}
