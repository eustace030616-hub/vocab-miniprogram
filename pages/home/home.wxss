.container {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 40rpx;
  margin-top: 80rpx;
}

.level-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: white;
  padding: 30rpx 60rpx;
  border-radius: 16rpx;
  margin-bottom: 60rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
}

.level-score {
  font-size: 64rpx;
  font-weight: bold;
  color: #07c160;
}

.level-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #666;
  margin-top: 5rpx;
}

.points-text {
  font-size: 24rpx;
  color: #666;
  margin-top: 10rpx;
}

.btn {
  width: 80%;
  margin: 15rpx 0;
  background-color: #07c160;
  color: white;
  border-radius: 8rpx;
}

.btn-secondary {
  background-color: #576775;
}

.btn-star {
  background-color: #ffd700;
  color: #333;
}
