.container {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  margin-bottom: 60rpx;
  margin-top: 60rpx;
}

.avatar-container {
  margin-bottom: 40rpx;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 80rpx;
  background-color: #07c160;
  display: flex;
  align-items: center;
  justify-content: center;
}

.avatar-text {
  font-size: 48rpx;
  font-weight: bold;
  color: white;
}

.level-display {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: white;
  padding: 30rpx 60rpx;
  border-radius: 16rpx;
  margin-bottom: 60rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.1);
  width: 80%;
}

.level-score {
  font-size: 64rpx;
  font-weight: bold;
  color: #07c160;
}

.level-name {
  font-size: 32rpx;
  font-weight: bold;
  color: #666;
  margin-top: 5rpx;
}

.stars-count {
  font-size: 24rpx;
  color: #999;
  margin-top: 10rpx;
}

.reset-section {
  width: 80%;
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 40rpx;
}

.reset-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 30rpx;
}

.btn-reset-all {
  width: 100%;
  background-color: #f44336;
  color: white;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.btn-reset-level {
  width: 100%;
  background-color: #ff9800;
  color: white;
  border-radius: 8rpx;
  margin-bottom: 20rpx;
}

.btn-reset-stars {
  width: 100%;
  background-color: #9c27b0;
  color: white;
  border-radius: 8rpx;
}

.btn-back {
  width: 80%;
  background-color: #576775;
  color: white;
  border-radius: 8rpx;
  margin-top: 40rpx;
}
