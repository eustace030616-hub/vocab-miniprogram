.container {
  padding: 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.title {
  font-size: 48rpx;
  font-weight: bold;
  margin-top: 80rpx;
  margin-bottom: 40rpx;
}

/* Score Section */
.score-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 20rpx;
}

.score {
  font-size: 72rpx;
  font-weight: bold;
  color: #07c160;
}

.score-label {
  font-size: 28rpx;
  color: #666;
  margin-top: 10rpx;
}

/* Points Section */
.points-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 20rpx 40rpx;
  background: white;
  border-radius: 12rpx;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.08);
}

.points {
  font-size: 48rpx;
  font-weight: bold;
  color: #ff9800;
}

.points-label {
  font-size: 24rpx;
  color: #999;
  margin-top: 5rpx;
}

/* Level Section */
.level-section {
  display: flex;
  flex-direction: column;
  align-items: center;
  margin-bottom: 30rpx;
  padding: 30rpx 60rpx;
  background: linear-gradient(135deg, #07c160, #04a85a);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}

.level-label {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-bottom: 5rpx;
}

.level-name {
  font-size: 56rpx;
  font-weight: bold;
  color: white;
}

.level-score {
  font-size: 28rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 5rpx;
}

/* Weak Levels */
.weak-levels {
  width: 100%;
  background: #fff3e0;
  border-radius: 12rpx;
  padding: 25rpx;
  margin-bottom: 20rpx;
  border-left: 6rpx solid #ff9800;
}

.weak-title {
  font-size: 28rpx;
  font-weight: bold;
  color: #e65100;
  display: block;
  margin-bottom: 15rpx;
}

.weak-list {
  display: flex;
  flex-wrap: wrap;
  gap: 15rpx;
}

.weak-item {
  display: flex;
  flex-direction: column;
  background: white;
  padding: 12rpx 20rpx;
  border-radius: 8rpx;
  align-items: center;
}

.weak-level {
  font-size: 28rpx;
  font-weight: bold;
  color: #333;
}

.weak-accuracy {
  font-size: 22rpx;
  color: #f44336;
  margin-top: 4rpx;
}

/* Performance */
.performance {
  padding: 25rpx 30rpx;
  background: white;
  border-radius: 12rpx;
  margin-bottom: 30rpx;
  width: 85%;
  text-align: center;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.05);
}

.perf-text {
  font-size: 30rpx;
  color: #333;
  font-weight: 500;
}

/* Buttons */
.buttons {
  width: 85%;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.btn {
  width: 100%;
  margin: 12rpx 0;
  border-radius: 12rpx;
  font-size: 34rpx;
  padding: 24rpx;
}

.retry-btn {
  background: linear-gradient(135deg, #07c160, #04a85a);
  color: white;
  box-shadow: 0 4rpx 12rpx rgba(7, 193, 96, 0.3);
}

.home-btn {
  background: #576775;
  color: white;
}
